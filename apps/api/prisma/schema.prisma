generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  CASH
  CARD
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  orders           Order[]
  customerProfiles CustomerProfile[]
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  createdAt DateTime @default(now())

  profile CustomerProfile?
  orders  Order[]
}

model CustomerProfile {
  id            String    @id @default(uuid())
  customerId    String
  company       String?
  customerType  String?
  status        String?
  source        String?
  responsibleId String?
  createdAt     DateTime  @default(now())
  lastContactAt DateTime?

  customer     Customer              @relation(fields: [customerId], references: [id])
  interactions CustomerInteraction[]
  responsible  User?                 @relation(fields: [responsibleId], references: [id])

  @@unique([customerId])
}

model CustomerInteraction {
  id        String   @id @default(uuid())
  profileId String
  type      String?
  note      String?
  createdAt DateTime @default(now())

  profile CustomerProfile @relation(fields: [profileId], references: [id])
}

model Category {
  id   String @id @default(uuid())
  name String

  products Product[]
}

model Product {
  id               String    @id @default(uuid())
  name             String
  description      String?
  categoryId       String?
  sku              String?   @unique
  barcode          String?
  stock            Int       @default(0)
  deactivationDate DateTime?
  createdAt        DateTime  @default(now())

  category       Category?       @relation(fields: [categoryId], references: [id])
  prices         Price[]
  costs          Cost[]
  orderItems     OrderItem[]
  recipeItems    RecipeItem[]    @relation("recipe_product")
  usedInRecipes  RecipeItem[]    @relation("recipe_ingredient")
  stockMovements StockMovement[]
}

model Price {
  id            String    @id @default(uuid())
  productId     String
  value         Decimal
  description   String?
  createdAt     DateTime  @default(now())
  deactivatedAt DateTime?

  product Product @relation(fields: [productId], references: [id])
}

model Cost {
  id            String    @id @default(uuid())
  productId     String
  value         Decimal
  createdAt     DateTime  @default(now())
  deactivatedAt DateTime?

  product Product @relation(fields: [productId], references: [id])
}

model RecipeItem {
  id           String @id @default(uuid())
  productId    String
  ingredientId String
  quantity     Float

  product    Product @relation("recipe_product", fields: [productId], references: [id])
  ingredient Product @relation("recipe_ingredient", fields: [ingredientId], references: [id])
}

model Order {
  id           String   @id @default(uuid())
  customerId   String?
  userId       String?
  deliveryDate DateTime @default(now())
  total        Decimal
  createdAt    DateTime @default(now())

  orderItems OrderItem[]
  payments   Payment[]
  user       User?       @relation(fields: [userId], references: [id])
  customer   Customer?   @relation(fields: [customerId], references: [id])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  amount    Decimal
  createdAt DateTime @default(now())

  method PaymentMethod
  order  Order         @relation(fields: [orderId], references: [id])
}

model StockMovement {
  id        String            @id @default(uuid())
  productId String
  quantity  Int
  reason    String?
  type      StockMovementType
  createdAt DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id])
}
