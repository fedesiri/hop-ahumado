generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BusinessLine {
  id         String            @id @default(uuid())
  name       String
  slug       String            @unique
  createdAt  DateTime          @default(now())
  categories Category[]
  expenses   Expense[]
  products   Product[]
  baselines  TreasuryBaseline?
}

model User {
  id                     String                  @id @default(uuid())
  name                   String
  email                  String                  @unique
  createdAt              DateTime                @default(now())
  customerProfiles       CustomerProfile[]
  notificationRecipients NotificationRecipient[]
  orders                 Order[]
}

model Notification {
  id         String                  @id @default(uuid())
  eventType  String
  message    String
  entityType String
  entityId   String
  createdAt  DateTime                @default(now())
  recipients NotificationRecipient[]

  @@index([createdAt])
  @@index([eventType, entityType, entityId])
}

model NotificationRecipient {
  id             String       @id @default(uuid())
  notificationId String
  userId         String
  readAt         DateTime?
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
}

model Customer {
  id        String           @id @default(uuid())
  name      String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  profile   CustomerProfile?
  orders    Order[]
}

model CustomerProfile {
  id             String                @id @default(uuid())
  customerId     String                @unique
  customerType   String?
  status         String?
  source         String?
  responsibleId  String?
  createdAt      DateTime              @default(now())
  contactName    String?
  email          String?
  generalNotes   String?
  nextFollowUpAt DateTime?
  phone          String?
  updatedAt      DateTime              @updatedAt
  interactions   CustomerInteraction[]
  opportunity    CustomerOpportunity?
  customer       Customer              @relation(fields: [customerId], references: [id])
  responsible    User?                 @relation(fields: [responsibleId], references: [id])
}

model CustomerInteraction {
  id        String              @id @default(uuid())
  profileId String
  createdAt DateTime            @default(now())
  channel   InteractionChannel?
  date      DateTime            @default(now())
  nextStep  String?
  notes     String?
  profile   CustomerProfile     @relation(fields: [profileId], references: [id])
}

model CustomerOpportunity {
  id                  String          @id @default(uuid())
  customerProfileId   String          @unique
  stage               String?
  estimatedValue      Decimal?
  expectedClosingDate DateTime?
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  customerProfile     CustomerProfile @relation(fields: [customerProfileId], references: [id])
}

model Category {
  id             String       @id @default(uuid())
  name           String
  businessLineId String
  businessLine   BusinessLine @relation(fields: [businessLineId], references: [id])
  products       Product[]
}

model StockLocation {
  id              String          @id @default(uuid())
  name            String
  isDefault       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  ordersFulfilled Order[]         @relation("OrderFulfillmentLocation")
  balances        StockBalance[]
  movementsFrom   StockMovement[] @relation("MovementFromLocation")
  movementsHere   StockMovement[] @relation("MovementAtLocation")
  movementsTo     StockMovement[] @relation("MovementToLocation")
}

model StockBalance {
  id         String        @id @default(uuid())
  productId  String
  locationId String
  quantity   Float         @default(0)
  location   StockLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
}

model Product {
  id               String          @id @default(uuid())
  name             String
  description      String?
  categoryId       String?
  sku              String?         @unique
  barcode          String?
  stock            Float           @default(0)
  deactivationDate DateTime?
  createdAt        DateTime        @default(now())
  unit             ProductUnit     @default(UNIT)
  businessLineId   String
  costs            Cost[]
  orderItems       OrderItem[]
  prices           Price[]
  businessLine     BusinessLine    @relation(fields: [businessLineId], references: [id])
  category         Category?       @relation(fields: [categoryId], references: [id])
  usedInRecipes    RecipeItem[]    @relation("recipe_ingredient")
  recipeItems      RecipeItem[]    @relation("recipe_product")
  stockBalances    StockBalance[]
  stockMovements   StockMovement[]

  @@index([businessLineId])
}

model Price {
  id            String    @id @default(uuid())
  productId     String
  value         Decimal
  description   String?
  createdAt     DateTime  @default(now())
  deactivatedAt DateTime?
  product       Product   @relation(fields: [productId], references: [id])
}

model Cost {
  id            String    @id @default(uuid())
  productId     String
  value         Decimal
  createdAt     DateTime  @default(now())
  deactivatedAt DateTime?
  product       Product   @relation(fields: [productId], references: [id])
}

model RecipeItem {
  id           String   @id @default(uuid())
  productId    String
  ingredientId String
  quantity     Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ingredient   Product  @relation("recipe_ingredient", fields: [ingredientId], references: [id])
  product      Product  @relation("recipe_product", fields: [productId], references: [id])
}

model Order {
  id                    String         @id @default(uuid())
  customerId            String?
  userId                String?
  deliveryDate          DateTime       @default(now())
  deliveredAt           DateTime?
  cancelledAt           DateTime?
  total                 Decimal
  /// Lista de precios al armar el pedido: mayorista, minorista o fabrica (opcional).
  priceListType         String?
  /// Notas u observaciones del pedido (opcional).
  comment               String?
  createdAt             DateTime       @default(now())
  fulfillmentLocationId String?
  isConsignment         Boolean        @default(false)
  customer              Customer?      @relation(fields: [customerId], references: [id])
  fulfillmentLocation   StockLocation? @relation("OrderFulfillmentLocation", fields: [fulfillmentLocationId], references: [id])
  user                  User?          @relation(fields: [userId], references: [id])
  orderItems            OrderItem[]
  payments              Payment[]
}

model OrderItem {
  id               String   @id @default(uuid())
  orderId          String
  productId        String
  quantity         Float
  price            Decimal?
  originalQuantity Float?
  order            Order    @relation(fields: [orderId], references: [id])
  product          Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String
  amount    Decimal
  createdAt DateTime      @default(now())
  method    PaymentMethod
  order     Order         @relation(fields: [orderId], references: [id])
}

model Expense {
  id             String        @id @default(uuid())
  amount         Decimal
  createdAt      DateTime      @default(now())
  method         PaymentMethod
  description    String?
  groupId        String        @default(uuid())
  businessLineId String
  businessLine   BusinessLine  @relation(fields: [businessLineId], references: [id])

  @@index([businessLineId])
}

model TreasuryBaseline {
  id             String       @id @default(uuid())
  openingCash    Decimal      @default(0)
  openingCard    Decimal      @default(0)
  deltaSince     DateTime
  updatedAt      DateTime     @updatedAt
  businessLineId String       @unique
  businessLine   BusinessLine @relation(fields: [businessLineId], references: [id])
}

model StockMovement {
  id             String            @id @default(uuid())
  productId      String
  quantity       Float
  reason         String?
  type           StockMovementType
  createdAt      DateTime          @default(now())
  locationId     String?
  fromLocationId String?
  toLocationId   String?
  fromLocation   StockLocation?    @relation("MovementFromLocation", fields: [fromLocationId], references: [id])
  location       StockLocation?    @relation("MovementAtLocation", fields: [locationId], references: [id])
  product        Product           @relation(fields: [productId], references: [id])
  toLocation     StockLocation?    @relation("MovementToLocation", fields: [toLocationId], references: [id])
}

enum PaymentMethod {
  CASH
  CARD
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

enum ProductUnit {
  UNIT
  KG
  G
  L
  ML
}

enum InteractionChannel {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  OTHER
}
