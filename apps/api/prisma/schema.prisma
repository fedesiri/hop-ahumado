generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  CASH
  CARD
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum ProductUnit {
  UNIT
  KG
  G
  L
  ML
}

enum InteractionChannel {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  OTHER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  orders           Order[]
  customerProfiles CustomerProfile[]
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile CustomerProfile?
  orders  Order[]
}

model CustomerProfile {
  id             String    @id @default(uuid())
  customerId     String
  contactName    String?
  phone          String?
  email          String?
  customerType   String?
  status         String?
  source         String?
  responsibleId  String?
  generalNotes   String?
  nextFollowUpAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer     Customer              @relation(fields: [customerId], references: [id])
  interactions CustomerInteraction[]
  responsible  User?                 @relation(fields: [responsibleId], references: [id])
  opportunity  CustomerOpportunity?

  @@unique([customerId])
}

model CustomerInteraction {
  id        String              @id @default(uuid())
  profileId String
  channel   InteractionChannel?
  date      DateTime            @default(now())
  notes     String?
  nextStep  String?
  createdAt DateTime            @default(now())

  profile CustomerProfile @relation(fields: [profileId], references: [id])
}

model CustomerOpportunity {
  id                  String    @id @default(uuid())
  customerProfileId   String    @unique
  stage               String?
  estimatedValue      Decimal?
  expectedClosingDate DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  customerProfile CustomerProfile @relation(fields: [customerProfileId], references: [id])
}

model Category {
  id   String @id @default(uuid())
  name String

  products Product[]
}

model Product {
  id               String      @id @default(uuid())
  name             String
  unit             ProductUnit @default(UNIT)
  description      String?
  categoryId       String?
  sku              String?     @unique
  barcode          String?
  stock            Float       @default(0)
  deactivationDate DateTime?
  createdAt        DateTime    @default(now())

  category       Category?       @relation(fields: [categoryId], references: [id])
  prices         Price[]
  costs          Cost[]
  orderItems     OrderItem[]
  recipeItems    RecipeItem[]    @relation("recipe_product")
  usedInRecipes  RecipeItem[]    @relation("recipe_ingredient")
  stockMovements StockMovement[]
}

model Price {
  id            String    @id @default(uuid())
  productId     String
  value         Decimal
  description   String?
  createdAt     DateTime  @default(now())
  deactivatedAt DateTime?

  product Product @relation(fields: [productId], references: [id])
}

model Cost {
  id            String    @id @default(uuid())
  productId     String
  value         Decimal
  createdAt     DateTime  @default(now())
  deactivatedAt DateTime?

  product Product @relation(fields: [productId], references: [id])
}

model RecipeItem {
  id           String   @id @default(uuid())
  productId    String
  ingredientId String
  quantity     Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product    Product @relation("recipe_product", fields: [productId], references: [id])
  ingredient Product @relation("recipe_ingredient", fields: [ingredientId], references: [id])
}

model Order {
  id           String   @id @default(uuid())
  customerId   String?
  userId       String?
  deliveryDate DateTime @default(now())
  total        Decimal
  createdAt    DateTime @default(now())

  orderItems OrderItem[]
  payments   Payment[]
  user       User?       @relation(fields: [userId], references: [id])
  customer   Customer?   @relation(fields: [customerId], references: [id])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Float
  price     Decimal

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  amount    Decimal
  createdAt DateTime @default(now())

  method PaymentMethod
  order  Order         @relation(fields: [orderId], references: [id])
}

model Expense {
  id          String        @id @default(uuid())
  amount      Decimal
  method      PaymentMethod
  description String?
  createdAt   DateTime      @default(now())

  // Se usa para agrupar splits (p.ej. efectivo + tarjeta) dentro de un mismo egreso.
  groupId String @default(uuid())
}

model StockMovement {
  id        String            @id @default(uuid())
  productId String
  quantity  Float
  reason    String?
  type      StockMovementType
  createdAt DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id])
}
