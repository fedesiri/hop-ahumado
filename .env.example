# Copia a .env y completa los valores.
# No subas .env al repositorio.

# ========== API (apps/api)
# PostgreSQL. Ejemplo local:
# DATABASE_URL="postgresql://usuario:password@localhost:5432/hop_ahumado"
DATABASE_URL=
PORT=3001
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGIN=http://localhost:3000

# ========== Web (apps/web)
# URL del backend (para proxy /api/* y llamadas desde el cliente)
NEXT_PUBLIC_API_URL=http://localhost:3001
